{
  "index_patterns": ["partner-logs-*", "dung-*", "wk03-*"],
  "template": {
    "mappings": {
      "dynamic": true,
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "service": {
          "type": "keyword"
        },
        "environment": {
          "type": "keyword"
        },
        "level": {
          "type": "keyword"
        },
        "event": {
          "type": "keyword"
        },
        "message": {
          "type": "text"
        },
        "status_code": {
          "type": "integer"
        },
        "endpoint": {
          "type": "keyword"
        },
        "path": {
          "type": "keyword"
        },
        "method": {
          "type": "keyword"
        }
      }
    }
  }
}

