{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/dung-standard-log/v1",
  "title": "Dung Standard Log Schema v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "@timestamp",
    "service",
    "environment",
    "level",
    "message"
  ],
  "properties": {
    "@timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "staging", "prod", "lab"]
    },
    "level": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARN", "ERROR", "FATAL"]
    },
    "event": {
      "type": "string"
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "status_code": {
      "type": "integer"
    },
    "endpoint": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "method": {
      "type": "string"
    },
    "duration_ms": {
      "type": "integer"
    }
  }
}

